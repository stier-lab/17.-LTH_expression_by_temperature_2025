# R
.Rhistory
.Rdata
.RData
.Ruserdata
.Rproj.user/
*.Rproj.user/

# targets
_targets/

# Regenerable outputs — kept ignored by default; un-ignore once stable
output/figures/*.pdf
output/models/*.rds

# OS
.DS_Store
Thumbs.db
._*

# Editor
.vscode/
.idea/

# Tool / MCP logs
*.log
excalidraw.log

# Sensitive
.env
.env.local
*.key
credentials.*
secrets/

# Large raw images (keep representative thumbnails only)
data/raw/photographs/*.JPG
data/raw/photographs/*.jpg
data/raw/photographs/*.NEF
data/raw/photographs/*.CR2

# Sequencing reads (never commit — store on Keck server)
data/raw/sequencing/*.fastq*
data/raw/sequencing/*.bam
data/raw/sequencing/*.cram

# Drive-staging artifacts (local only)
/tmp/lth-staging/
